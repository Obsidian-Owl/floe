# Environment variables for floe development
# Copy to .env and customize as needed

# Use latest Pyright version (avoids version warning)
PYRIGHT_PYTHON_FORCE_VERSION=latest

# Python path for testing (if not using pytest pythonpath config)
# PYTHONPATH=packages/floe-core/src

# =============================================================================
# Agent Memory (Epic 10A) - Cognee Integration
# =============================================================================
# Required for agent-memory integration tests and CLI commands

# Cognee Cloud API key (get from https://www.cognee.ai/)
COGNEE_API_KEY=

# LLM Provider - choose one:
# Option 1: OpenAI (default)
OPENAI_API_KEY=

# Option 2: Anthropic (set LLM_PROVIDER=anthropic in config)
# ANTHROPIC_API_KEY=

# Optional: Override Cognee API URL (defaults to https://api.cognee.ai)
# COGNEE_API_URL=https://api.cognee.ai

# =============================================================================
# DevPod (Remote E2E on Hetzner)
# =============================================================================

# Hetzner Cloud API token (read + write)
DEVPOD_HETZNER_TOKEN=
# Workspace name (default: floe)
DEVPOD_WORKSPACE=floe
# Restart a saved stopped workspace during readiness checks (1=true, 0=false)
DEVPOD_AUTO_START=1
# Provider used when starting the workspace via devpod up
DEVPOD_PROVIDER=hetzner
# Devcontainer path used when starting the workspace via devpod up
DEVPOD_DEVCONTAINER=.devcontainer/hetzner/devcontainer.json
# Optional explicit DevPod source. If unset, scripts use origin@current-branch.
# Example: git:https://github.com/Obsidian-Owl/floe@main
DEVPOD_SOURCE=
# Optional branch/ref when deriving DEVPOD_SOURCE from the Git remote.
DEVPOD_GIT_REF=
# Set to 1 only for small repos/debugging. Default remote Git source avoids
# uploading this full worktree to Hetzner.
DEVPOD_ALLOW_LOCAL_SOURCE=0
# Local port for K8s API tunnel
DEVPOD_K8S_API_PORT=26443
# Remote repo root inside the DevPod workspace (matches the default devcontainer)
DEVPOD_REMOTE_WORKDIR=/workspace
# Detached remote E2E controls used by make devpod-test
DEVPOD_REMOTE_RUN_ROOT=/tmp/floe-devpod-e2e
DEVPOD_REMOTE_E2E_TIMEOUT=7200
DEVPOD_REMOTE_POLL_INTERVAL=20
DEVPOD_REMOTE_POLL_FAILURE_LIMIT=30
DEVPOD_UP_RECOVERY_TIMEOUT=600
DEVPOD_UP_RECOVERY_INTERVAL=15
# Set to 1 to skip automatic Kind/platform setup in the Hetzner postStart hook.
# make devpod-test sets this itself and runs E2E through a detached remote phase.
FLOE_DEVPOD_SKIP_POSTSTART_SETUP=0
# Remote E2E runs inside the DevPod workspace network and skips host service
# tunnels by default. Set to 1 only when you also need local browser/API access.
DEVPOD_ENABLE_REMOTE_TUNNELS=0
# Optional manifest override for local/test runners; defaults to demo/manifest.yaml
FLOE_MANIFEST_PATH=
# Optional demo image repository override for local/Kind validation
FLOE_DEMO_IMAGE_REPOSITORY=
# Optional demo image tag override; blank uses the repo-derived default tag helper
FLOE_DEMO_IMAGE_TAG=
# Docker config mode for public image pulls (`isolated` avoids broken helper proxies)
FLOE_PUBLIC_DOCKER_CONFIG_MODE=isolated
# Optional DOCKER_CONFIG directory for public image pulls; blank uses a temp config
FLOE_PUBLIC_DOCKER_CONFIG_DIR=
# Build engine for public docker builds (`classic` avoids broken DevPod BuildKit auth)
FLOE_PUBLIC_DOCKER_BUILD_ENGINE=classic
