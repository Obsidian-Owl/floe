#!/usr/bin/env bash
# Pre-PR Quality Gate
# Blocks PR creation unless quality checks pass
#
# Called by Claude Code hook: PreToolUse on "gh pr create"
# Returns exit code 0 to allow, non-zero to block

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
PROJECT_ARTIFACTS_ROOT="${PROJECT_ROOT}/.specwright"
GIT_DIR="$(git -C "$PROJECT_ROOT" rev-parse --path-format=absolute --git-dir 2>/dev/null || true)"
GIT_COMMON_DIR="$(git -C "$PROJECT_ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
REPO_STATE_ROOT="${GIT_COMMON_DIR:+$GIT_COMMON_DIR/specwright}"
WORKTREE_STATE_ROOT="${GIT_DIR:+$GIT_DIR/specwright}"
SESSION_FILE="${WORKTREE_STATE_ROOT:+$WORKTREE_STATE_ROOT/session.json}"
WORKFLOW_ROOT="${REPO_STATE_ROOT:+$REPO_STATE_ROOT/work}"
LEGACY_WORKFLOW="${PROJECT_ARTIFACTS_ROOT}/state/workflow.json"

log_info() {
    echo -e "${GREEN}[pre-pr-gate]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[pre-pr-gate]${NC} $1" >&2
}

log_error() {
    echo -e "${RED}[pre-pr-gate]${NC} $1" >&2
}

check_dependencies() {
    # Check for required tools
    if ! command -v jq &>/dev/null; then
        log_error "jq is required but not installed."
        log_error "Install with: brew install jq (macOS) or apt install jq (Linux)"
        return 1
    fi
    return 0
}

check_quality_state() {
    local workflow_file=""
    local work_id=""
    local legacy_mode=0
    local current_branch=""
    local session_branch=""

    current_branch="$(git -C "$PROJECT_ROOT" branch --show-current 2>/dev/null || true)"

    if [[ -n "${SESSION_FILE:-}" ]] && [[ -f "$SESSION_FILE" ]]; then
        work_id=$(jq -r '.attachedWorkId // empty' "$SESSION_FILE")
        if [[ -z "$work_id" ]]; then
            log_warn "Specwright session is present but no work is attached."
            return 2
        fi

        session_branch=$(jq -r '.branch // empty' "$SESSION_FILE")
        if [[ -n "$session_branch" ]] && [[ -n "$current_branch" ]] && [[ "$session_branch" != "$current_branch" ]]; then
            log_warn "Specwright session is attached to branch '$session_branch', not current branch '$current_branch'."
            return 2
        fi

        if [[ -z "${WORKFLOW_ROOT:-}" ]]; then
            log_error "Could not resolve the Specwright runtime state root."
            return 1
        fi

        workflow_file="${WORKFLOW_ROOT}/${work_id}/workflow.json"
        if [[ ! -f "$workflow_file" ]]; then
            log_error "Attached Specwright runtime workflow is missing for work '$work_id'."
            log_error "Expected: $workflow_file"
            return 1
        fi
    elif [[ -f "$LEGACY_WORKFLOW" ]]; then
        workflow_file="$LEGACY_WORKFLOW"
        work_id=$(jq -r '.currentWork.id // empty' "$workflow_file")
        if [[ -z "$work_id" ]]; then
            log_warn "Legacy Specwright workflow has no active work."
            return 2
        fi
        legacy_mode=1
    else
        return 2
    fi

    # Check if state is recent (within last hour)
    local state_time
    state_time=$(stat -f %m "$workflow_file" 2>/dev/null || stat -c %Y "$workflow_file" 2>/dev/null)
    local current_time
    current_time=$(date +%s)
    local age=$((current_time - state_time))

    if [[ $age -gt 3600 ]]; then
        log_warn "Quality state is stale (${age}s old). Re-run checks."
        return 1
    fi

    if [[ -z "$work_id" ]]; then
        log_error "No active Specwright work is attached to this worktree."
        return 1
    fi

    local failed_gates
    if [[ "$legacy_mode" -eq 1 ]]; then
        if [[ "$(jq -r --arg work_id "$work_id" '(.gates[$work_id] != null)' "$workflow_file")" != "true" ]]; then
            log_error "No gate results for work '$work_id'. Run /sw-verify first."
            return 1
        fi
        failed_gates=$(jq -r --arg work_id "$work_id" '(.gates[$work_id] // {}) | to_entries[]? | select((.value.status // "") == "FAIL" or (.value.status // "") == "ERROR") | .key' "$workflow_file")
    else
        if [[ "$(jq -r '(.gates // {}) | length > 0' "$workflow_file")" != "true" ]]; then
            log_error "No gate results for work '$work_id'. Run /sw-verify first."
            return 1
        fi
        failed_gates=$(jq -r '(.gates // {}) | to_entries[]? | select((.value.verdict // "") == "FAIL" or (.value.verdict // "") == "ERROR") | .key' "$workflow_file")
    fi

    if [[ -n "$failed_gates" ]]; then
        log_error "Failed gates for '$work_id':"
        echo "$failed_gates" | while read -r gate; do
            log_error "  - $gate"
        done
        log_error "Run /sw-verify to fix and re-check."
        return 1
    fi

    return 0
}

check_no_uncommitted_changes() {
    log_info "Checking for uncommitted changes..."

    if [[ -n $(git status --porcelain) ]]; then
        log_error "Uncommitted changes detected. Commit or stash before PR."
        git status --short >&2
        return 1
    fi

    return 0
}

check_branch_up_to_date() {
    log_info "Checking if branch is up to date with main..."

    # Fetch latest (with explicit refspec)
    git fetch origin main --quiet 2>/dev/null || true

    # Validate refs exist before comparing
    local origin_main="origin/main"
    local head_ref="HEAD"

    if ! git rev-parse --verify "$origin_main" >/dev/null 2>&1; then
        log_warn "Could not find origin/main, skipping branch check"
        return 0
    fi

    if ! git rev-parse --verify "$head_ref" >/dev/null 2>&1; then
        log_warn "Could not verify HEAD, skipping branch check"
        return 0
    fi

    # Check if we're behind main using validated refs
    local behind
    behind=$(git rev-list --count "${head_ref}..${origin_main}" 2>/dev/null || echo "0")

    if [[ "$behind" -gt 0 ]]; then
        log_warn "Branch is ${behind} commits behind main. Consider rebasing."
        # Warning only, not blocking
    fi

    return 0
}

main() {
    log_info "Running pre-PR quality gate..."

    # Check dependencies first
    check_dependencies || exit 1

    local failed=0

    # Essential checks (always run)
    check_no_uncommitted_changes || failed=1

    # Quality state check (if state file exists)
    if [[ -f "$LEGACY_WORKFLOW" ]] || [[ -f "$SESSION_FILE" ]]; then
        local quality_status=0
        check_quality_state || quality_status=$?
        case "$quality_status" in
            0)
                ;;
            1)
                failed=1
                ;;
            2)
                log_warn "Proceeding with basic checks only..."
                ;;
            *)
                failed=1
                ;;
        esac
    else
        log_warn "No Specwright session or legacy workflow state found."
        log_warn "For full quality gate, run:"
        log_warn "  1. /sw-verify"
        log_warn "  2. Fix any gate findings"
        log_warn "  3. Re-run /sw-verify until all gates pass"
        log_warn "  4. Critic agent approval"
        log_warn ""
        log_warn "Proceeding with basic checks only..."
    fi

    # Branch check (warning only)
    check_branch_up_to_date || true

    if [[ $failed -ne 0 ]]; then
        log_error ""
        log_error "========================================="
        log_error "PRE-PR QUALITY GATE FAILED"
        log_error "========================================="
        log_error ""
        log_error "Required actions:"
        log_error "  1. Run /sw-verify"
        log_error "  2. Fix any gate findings"
        log_error "  3. Re-run /sw-verify until all gates pass"
        log_error "  4. Get critic agent approval"
        log_error "  5. Commit all changes"
        log_error ""
        exit 1
    fi

    log_info ""
    log_info "========================================="
    log_info "PRE-PR QUALITY GATE PASSED"
    log_info "========================================="
    log_info ""

    exit 0
}

main "$@"
