{
  "name": "floe Hetzner Remote (DevPod)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "args": {
      "TZ": "${localEnv:TZ:UTC}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0",
      "KIND_VERSION": "0.22.0",
      "KUBECTL_VERSION": "1.29.0",
      "HELM_VERSION": "3.16.4",
      "FLUX_VERSION": "2.5.1",
      "UV_VERSION": "0.7.2"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": true,
      "dockerDashComposeVersion": "v2"
    }
  },
  "hostRequirements": {
    "cpus": 8,
    "memory": "24gb",
    "storage": "64gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-shellhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "KUBECONFIG": "/home/node/.kube/config",
    "TERM": "xterm-256color"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "cd /workspace && uv sync --frozen 2>/dev/null || true",
  "postStartCommand": "bash /workspace/.devcontainer/hetzner/postStartCommand.sh"
}
